{
    "compilerOptions": {
        "allowArbitraryExtensions": true,
        "declaration": true,
        "declarationMap": true,
        "lib": [
            "esnext"
        ],
        "module": "NodeNext",
        "outDir": "./dist",
        "plugins": [
            {
                "transform": "./m13-es-transformer.cjs",
                "after": true,
            }
        ],
        "rewriteRelativeImportExtensions": true,
        "target": "esnext",
        "verbatimModuleSyntax": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "removeComments": true,
        "experimentalDecorators": true,
        "noImplicitOverride": true,
        "strict": true,
        "strictNullChecks": true,
        "allowJs": false,
        "noImplicitAny": true,
        "sourceMap": true
    },
    "include": [
        "./src"
    ],
    "exclude": [
        "./spec/**/*"
    ]
}